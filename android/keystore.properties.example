# Copy to android/keystore.properties (never commit the real file).
# Used by android/app/build.gradle.kts for release signing.
#
# Dev shortcut (same signature as debug APK installs): point storeFile at
# %USERPROFILE%\.android\debug.keystore with alias androiddebugkey / password android.
storeFile=../release.keystore
storePassword=change-me
keyAlias=deepseek-mobile
keyPassword=change-me
