# Copy to android/keystore.properties (never commit the real file).
# Used by android/app/build.gradle.kts for release signing.
#
# === DEV SIGNING (current default for easy development) ===
# Use the standard Android debug keystore. This way "release" APKs have
# the same signature as debug builds and can upgrade over existing debug installs.
# Example (what is actually used in this repo for dev):
#   storeFile=C:/Users/vladi/.android/debug.keystore
#   storePassword=android
#   keyAlias=androiddebugkey
#   keyPassword=android
#
# === PRODUCTION / REAL SIGNING ("по-настоящему") ===
# For public GitHub Releases, Google Play (AAB), and proper signature
# consistency across all user devices, generate a real release keystore ONCE:
#
#   keytool -genkey -v -keystore release.keystore -alias deepseek-mobile \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# Then put the real keystore.properties pointing to your protected release.keystore
# (keep the .keystore file and this properties file OUT of git).
#
#   storeFile=../release.keystore          # or absolute path
#   storePassword=YOUR_STRONG_PASSWORD
#   keyAlias=deepseek-mobile
#   keyPassword=YOUR_STRONG_PASSWORD
#
# Run without -AllowUnsigned:
#   .\scripts\build-release-apk.ps1
#   .\scripts\publish-github-release.ps1
#
# CI can do the same using GitHub secrets (see .github/workflows/release.yml).
storeFile=../release.keystore
storePassword=change-me
keyAlias=deepseek-mobile
keyPassword=change-me
