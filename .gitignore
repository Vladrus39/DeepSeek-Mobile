target/
.DS_Store

# Local dev wrappers in repo root (not part of the product)
/*.bat
.env
*.log
/dist
/android/keystore.properties
/android/*.keystore
/android/release.keystore

# PC host binaries copied for offline pairing ZIP (see scripts/build-pc-host-bundles.ps1)
/tools/pc-host/bin/**/*
!tools/pc-host/bin/README.md

# Sideloaded Termux APK/bootstrap (see scripts/install-termux-offline.ps1)
/tools/android/third-party/*.apk
/tools/android/third-party/bootstrap-*.zip

# Project-local Android SDK copy (large; reproducible via sync-sdk-from-system.ps1)
/tools/android/downloads/
/tools/android/sdk/platform-tools/
/tools/android/sdk/build-tools/
/tools/android/sdk/platforms/
/tools/android/sdk/licenses/
/tools/android/sdk/.knownPackages
/tools/android/sdk/ndk/**
!tools/android/sdk/ndk/README.md

# Windows system cache files
%SystemDrive%/
